@model IEnumerable<Phorcys.Domain.LogSample>
@{
    ViewData["Title"] = "Dive Samples";
    var sampleCount = Model.Count();
    var totalMinutes = (int)Math.Ceiling(sampleCount / 6.0);
    var minutesPerLabel = (int)Math.Ceiling(totalMinutes / 20.0); // target ~20 labels at desktop width
    var niceMinutes = new[] { 1, 2, 5, 10, 15, 20, 30, 60 }.FirstOrDefault(n => n >= minutesPerLabel);
    if (niceMinutes == 0) niceMinutes = 60;
    var initialStep = niceMinutes * 6;
}

<section class="jumbotron text-center">
    <div class="container">
        <h1 class="jumbotron-heading">Dive #@ViewBag.DiveNumber — @ViewBag.DiveTitle — Computer Samples</h1>
    </div>
</section>

<style>
    #SamplesGrid .k-header {
        white-space: normal;
        word-wrap: break-word;
    }
    .k-chart-tooltip-wrapper {
        transform: translate(20px, 20px);
    }
</style>

<div class="row">
    <div class="col-12">
        @(Html.Kendo().TabStrip()
            .Name("samplesTabStrip")
            .Items(items =>
            {
                items.Add().Text("Dive Profile").Selected(true)
                    .Content(@<text>
                        <div class="p-3">
                            @(Html.Kendo().Chart(Model)
                                .Name("DiveProfileChart")
                                .Series(series =>
                                {
                                    series.Line(s => s.Depth)
                                        .Name("Depth")
                                        .Color("blue")
                                        .Axis("depthAxis")
                                        .Markers(m => m.Visible(false));
                                    series.Line(s => s.Temperature)
                                        .Name("Temp")
                                        .Axis("rightAxis")
                                        .Markers(m => m.Visible(false));
                                    series.Line(s => s.NoDecoLimitMinutes)
                                        .Name("NDL (min)")
                                        .Color("red")
                                        .Axis("rightAxis")
                                        .Markers(m => m.Visible(false));
                                })
                                .CategoryAxis(axis => axis
                                    .Field("ElapsedSeconds")
                                    .Title(t => t.Text("Elapsed Time (min)"))
                                    .Labels(l => l
                                        .Template("#= Math.round(value / 60) #")
                                        .Step(initialStep)
                                        .Rotation(-45)
                                    )
                                )
                                .ValueAxis(axis => axis.Numeric()
                                    .Name("depthAxis")
                                    .Reverse(true)
                                    .Title(t => t.Text("Depth"))
                                )
                                .ValueAxis(axis => axis.Numeric()
                                    .Name("rightAxis")
                                    .Title(t => t.Text("Temp / NDL (min)"))
                                )
                                .Legend(legend => legend
                                    .Position(ChartLegendPosition.Bottom)
                                    .Visible(true)
                                )
                                .Tooltip(tooltip => tooltip
                                    .Visible(true)
                                    .Shared(true)
                                )
                                .HtmlAttributes(new { style = "height: 500px;" })
                            )
                        </div>
                    </text>);

                items.Add().Text("Sample Data")
                    .Content(@<text>
                        <div class="p-3">
                            @(Html.Kendo().Grid(Model)
                                .Name("SamplesGrid")
                                .Columns(columns =>
                                {
                                    columns.Bound(s => s.LogSampleId).Hidden(true);
                                    columns.Bound(s => s.DiveComputerLogId).Hidden(true);
                                    columns.Bound(s => s.ElapsedSeconds).Title("Elapsed (s)").Width(125);
                                    columns.Bound(s => s.Depth).Width(125);
                                    columns.Bound(s => s.FirstDecoStopDepth).Title("1st Deco Depth").Width(125);
                                    columns.Bound(s => s.TimeToSurfaceMinutes).Title("TTS (min)").Width(125);
                                    columns.Bound(s => s.AvgPPO2).Title("Avg PPO2").Width(125);
                                    columns.Bound(s => s.FractionO2).Title("FO2").Width(125);
                                    columns.Bound(s => s.FractionHe).Title("FHe").Width(125);
                                    columns.Bound(s => s.FirstDecoStopMinutes).Title("1st Deco (min)").Width(125);
                                    columns.Bound(s => s.NoDecoLimitMinutes).Title("NDL (min)").Width(125);
                                    columns.Bound(s => s.CircuitMode).Title("Circuit Mode").Width(125);
                                    columns.Bound(s => s.CCRMode).Title("CCR Mode").Width(125);
                                    columns.Bound(s => s.Temperature).Width(125);
                                    columns.Bound(s => s.GasSwitchNeeded).Title("Gas Switch").Width(125);
                                    columns.Bound(s => s.ExternalPPO2Active).Title("Ext PPO2").Width(125);
                                    columns.Bound(s => s.SetPointType).Title("Set Point").Width(125);
                                    columns.Bound(s => s.CircuitSwitchType).Title("Circuit Switch").Width(125);
                                    columns.Bound(s => s.O2Sensor1Millivolts).Title("O2 S1 (mv)").Width(125);
                                    columns.Bound(s => s.O2Sensor2Millivolts).Title("O2 S2 (mv)").Width(125);
                                    columns.Bound(s => s.O2Sensor3Millivolts).Title("O2 S3 (mv)").Width(125);
                                    columns.Bound(s => s.BatteryVoltage).Title("Battery (V)").Width(125);
                                    columns.Bound(s => s.AscentRate).Title("Ascent Rate").Width(125);
                                    columns.Bound(s => s.SafeAscentDepth).Title("Safe Ascent Depth").Width(125);
                                    columns.Bound(s => s.CO2Millibar).Title("CO2 (mbar)").Width(125);
                                })
                                .Height(720)
                                .Mobile()
                                .Resizable(resize => resize.Columns(true))
                                .ToolBar(toolbar =>
                                {
                                    toolbar.Excel();
                                    toolbar.Pdf();
                                    toolbar.Search();
                                })
                                .Pdf(pdf => pdf.ProxyURL(Url.Action("Excel_Export_Save", "Grid")))
                                .Excel(excel => excel.ProxyURL(Url.Action("Excel_Export_Save", "Grid")))
                                .ColumnMenu(col => col.Filterable(true))
                                .Pageable(pageable => pageable
                                    .ButtonCount(6)
                                    .Refresh(true)
                                    .PageSizes(new[] { 500, 1000, 2000 }))
                                .Sortable()
                                .Groupable()
                                .Filterable()
                                .Scrollable()
                            )
                        </div>
                    </text>);
            })
        )
    </div>
</div>

<div class="mt-4">
    @(Html.Kendo().Button()
        .Name("cancelButton")
        .HtmlAttributes(new { @class = "btn btn-normal", onclick = "redirectToSamplesIndex();" })
        .ImageUrl(Url.Content("~/icons/RedXMark.png"))
        .Content("Cancel")
    )
</div>

<div id="samplesConfig"
     data-index-url="@Url.Action("Index", "Dive")"
     data-sample-count="@sampleCount"></div>

@section Scripts {
    <script>
        var samplesConfig = document.getElementById("samplesConfig");
        var samplesIndexUrl = samplesConfig ? samplesConfig.dataset.indexUrl : "/Dive";
        var sampleCount = parseInt(samplesConfig ? samplesConfig.dataset.sampleCount : "0") || 0;

        // Shearwater logs at 10-second intervals — 6 samples per minute.
        var SAMPLES_PER_MINUTE = 6;
        var NICE_INTERVALS = [1, 2, 5, 10, 15, 20, 30, 60];
        var MIN_LABEL_PX = 60;

        function calculateChartStep(containerWidth) {
            var totalMinutes = Math.ceil(sampleCount / SAMPLES_PER_MINUTE);
            var maxLabels = Math.max(Math.floor(containerWidth / MIN_LABEL_PX), 1);
            var minutesPerLabel = Math.ceil(totalMinutes / maxLabels);
            var niceMinutes = NICE_INTERVALS.find(function (n) { return n >= minutesPerLabel; }) || 60;
            return niceMinutes * SAMPLES_PER_MINUTE;
        }

        function applyChartStep() {
            var chart = $("#DiveProfileChart").data("kendoChart");
            if (!chart) return;
            var step = calculateChartStep($("#DiveProfileChart").width());
            chart.setOptions({
                categoryAxis: {
                    field: "ElapsedSeconds",
                    title: { text: "Elapsed Time (min)" },
                    labels: {
                        template: "#= Math.round(value / 60) #",
                        step: step,
                        rotation: -45
                    }
                }
            });
        }

        function redirectToSamplesIndex() {
            window.location.href = samplesIndexUrl;
        }

        var resizeTimer;
        $(window).on("resize", function () {
            clearTimeout(resizeTimer);
            resizeTimer = setTimeout(applyChartStep, 200);
        });

        $(document).ready(function () {
            var grid = $("#SamplesGrid").data("kendoGrid");
            if (grid) grid.dataSource.pageSize(500);

            $("#samplesTabStrip").data("kendoTabStrip").bind("activate", function (e) {
                if ($(e.item).index() === 1) {
                    var g = $("#SamplesGrid").data("kendoGrid");
                    if (g) g.resize();
                }
            });

            applyChartStep();
        });
    </script>
}
